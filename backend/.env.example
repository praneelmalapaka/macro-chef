NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/macrochef?sslmode=require
DATABASE_SCHEMA=public
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Gmail SMTP, backend only. Do not expose these to Flutter.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_gmail_address@gmail.com

# Dev/test only. Leave false in production.
SMTP_SKIP_SEND=false

# Dev/test only. Enables POST /auth/dev-login for local work.
DEV_LOGIN_ENABLED=false
DEV_LOGIN_USERNAME=dev
DEV_LOGIN_DISPLAY_NAME=Dev Chef
DEV_LOGIN_EMAIL=dev@your-local-domain.test
